{
  "name": "nomi-blog",
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --ssrManifest .vite/ssr-manifest.json --outDir dist/client",
    "build:server": "vite build --ssr src/engine/entry-server.tsx --outDir dist/server",
    "generate": "vite build --ssrManifest .vite/ssr-manifest.json --outDir dist/static && tsx ./src/engine/prerender.ts",
    "serve": "tsx src/engine/server.ts --prod"
  },
  "dependencies": {
    "@bprogress/core": "^1.3.4",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "hast-util-to-html": "^9.0.5",
    "marked": "^17.0.1",
    "mermaid": "^11.12.2",
    "refractor": "^5.0.0",
    "solid-js": "^1.9.10",
    "tocbot": "^4.36.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/lexend": "^5.2.11",
    "@tailwindcss/vite": "^4.1.18",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "sirv": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-compression2": "^2.4.0",
    "vite-plugin-solid": "^2.11.10"
  },
  "engines": {
    "node": ">=22"
  }
}